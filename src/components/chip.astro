---

interface Props {
  name: string;
  icon: string;
  color?: string;
}

const { name, icon, color} = Astro.props;

---

<span
  class={`border inline-flex rounded-full p-0.5 px-2 text-xs gap-2`}
  style={{
    borderColor: color,
    color: color,
    backgroundColor: color + '10',
    
  }}
>
  <img
    width="16"
    src={icon}
  />
  {name}</span
>
